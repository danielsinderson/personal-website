---
const year = new Date().getFullYear();
---

<footer>
  <hr />
  <p>
    Daniel Sinderson &middot; {year} &middot; made with <a href="https://astro.build/">Astro</a>
  </p>
</footer>

<style>
  footer {
    padding-top: 2em;
    padding-bottom: 1em;
  }

  footer hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0 0 0.75em;
  }

  footer p {
    font-size: 0.85em;
    color: #777;
  }
</style>
