---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const recentPosts = allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 5);

const works = [
    {
        href: "/posts/book-tensegrity",
        title: "Tensegrity",
        description: "A collection of poems",
        tags: ["arts"],
    },
    {
        href: "/modeling-open-systems.pdf",
        title: "Modeling Open Systems with Category Theory",
        description: "Undergraduate capstone paper",
        tags: ["research"],
    },
    {
        href: "/posts/book-vocoder",
        title: "Vocoder",
        description: "A collection of poems (in revision)",
        tags: ["arts"],
    },
    {
        href: "/posts/rust-and-ruin-1",
        title: "Rust & Ruin",
        description: "Tabletop roleplaying game (v0.5 playtesting)",
        tags: ["games"],
    },
    {
        href: "/posts/diyphd-rework",
        title: "DIY Graduate School",
        description: "Self-study graduate curriculum",
        tags: ["learning"],
    },
    {
        href: "/posts/synthesizers-1",
        title: "Terrible Synthesizers",
        description: "Arduino-based synthesizer projects",
        tags: ["electronics"],
    },
    {
        href: "/posts/journey-to-the-bright-and-wild-1",
        title: "Journey to the Bright and Wild",
        description: "A TTRPG designed for kids",
        tags: ["games"],
    },
];

const allTags = [...new Set(works.flatMap((item) => item.tags))].sort();
---

<Layout title="DRS" description="Working Theories — Daniel Sinderson">
    <div id="home">
        <section id="about">
            <h1>Hello, I'm Daniel</h1>
            <p>
                I'm a writer and data scientist living in Ashland, OR with my
                wife and our two kids. I write poetry and nonfiction, am
                pursuing a self-study graduate curriculum in applied
                mathematics, and I have too many hobbies.
            </p>
            <p>
                <strong>Degrees:</strong> A.A.S. Electronics | B.A. Anthropology |
                B.S. Mathematics
            </p>
        </section>

        <section id="interests">
            <h1>Interests</h1>
            <ul class="plain-list">
                <li>Formal Theories</li>
                <li>Poetry</li>
                <li>Anthropology</li>
                <li>Game Design</li>
                <li>TTRPGs</li>
                <li>Synthesizers</li>
            </ul>
        </section>

        <section id="skills">
            <h1>Skills</h1>
            <ul class="plain-list">
                <li>Mathematics</li>
                <li>Data Analysis</li>
                <li>Automation</li>
                <li>Writing</li>
                <li>Electronics</li>
                <li>Eating Spicy Food</li>
            </ul>
        </section>

        <section id="works" class="filterable-section">
            <h1>Works & Projects</h1>
            <div id="card-filter" class="filter-bar">
                <button id="works-clear-btn" class="filter-btn active"
                    >all</button
                >
                {
                    allTags.map((tag) => (
                        <button class="filter-btn" data-filter={tag}>
                            {tag}
                        </button>
                    ))
                }
            </div>
            <ul class="card-list">
                {works.map((w) => <Card {...w} />)}
            </ul>
        </section>

        <section id="blog">
            <h1>Recent Posts</h1>
            <ul class="post-list">
                {
                    recentPosts.map((post) => (
                        <li>
                            <a href={`/posts/${post.slug}`}>
                                {post.data.title}
                            </a>
                            <span class="post-meta">
                                <span class="badge">{post.data.topic}</span>
                                <span class="badge">{post.data.type}</span>
                                <time
                                    datetime={post.data.pubDate.toISOString()}
                                >
                                    {post.data.pubDate.toLocaleDateString(
                                        "en-US",
                                        { year: "numeric", month: "short" },
                                    )}
                                </time>
                            </span>
                        </li>
                    ))
                }
            </ul>
            <p class="all-posts-link"><a href="/posts">All posts →</a></p>
        </section>
    </div>
</Layout>

<style>
    #home {
        max-width: 800px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
        gap: 1.5em;
    }

    #about {
        grid-column: 1 / 3;
    }
    #interests {
        grid-column: 1 / 2;
    }
    #skills {
        grid-column: 2 / 3;
    }
    #works {
        grid-column: 1 / 3;
    }
    #blog {
        grid-column: 1 / 3;
        margin-bottom: 1em;
    }

    /* plain lists */
    .plain-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .plain-list li {
        padding: 0.025em 0;
    }

    /* filter bar */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4em;
        margin-bottom: 0.75em;
    }

    .filter-btn,
    #works-clear-btn {
        padding: 0.2em 0.65em;
        border: 1px solid var(--color-border);
        border-radius: 20px;
        background: none;
        cursor: pointer;
        font-size: 0.95em;
        font-weight: 600;
        color: var(--color-text);
        font-family: inherit;
        transition:
            border-color 0.15s,
            background 0.15s,
            color 0.15s;
    }

    .filter-btn:hover,
    #works-clear-btn:hover {
        border-color: var(--color-text);
    }

    .filter-btn.active {
        background-color: var(--color-accent);
        color: var(--color-bg);
        border-color: var(--color-accent);
    }

    /* cards */
    .card-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5em;
    }

    /* post list */
    .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .post-list li {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5em;
        padding: 0.5em 0;
        border-bottom: 1px solid var(--color-border);
    }

    .post-meta {
        display: flex;
        align-items: baseline;
        gap: 0.35em;
        color: var(--color-muted);
        font-size: 0.85em;
    }

    .badge {
        display: inline-block;
        padding: 0.1em 0.4em;
        border: 1px solid
            color-mix(
                in srgb,
                var(--color-accent-text) 30%,
                var(--color-border)
            );
        border-radius: 3px;
        font-size: 0.85em;
        color: var(--color-accent-text);
    }

    .all-posts-link {
        font-size: 0.9em;
        margin-top: 0.5em;
    }
</style>

<script>
    const tagButtons = document.querySelectorAll<HTMLButtonElement>(
        "#card-filter .filter-btn[data-filter]",
    );
    const allBtn = document.getElementById("works-clear-btn")!;
    const cards = document.querySelectorAll<HTMLElement>(".card");

    let activeFilter: string | null = null;

    function applyFilter() {
        cards.forEach((card) => {
            const tags = card.dataset.tags ? card.dataset.tags.split(",") : [];
            card.hidden = activeFilter !== null && !tags.includes(activeFilter);
        });
        allBtn.classList.toggle("active", activeFilter === null);
    }

    tagButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter!;
            activeFilter = activeFilter === filter ? null : filter;
            tagButtons.forEach((b) => b.classList.remove("active"));
            if (activeFilter) btn.classList.add("active");
            applyFilter();
        });
    });

    allBtn.addEventListener("click", () => {
        activeFilter = null;
        tagButtons.forEach((b) => b.classList.remove("active"));
        applyFilter();
    });
</script>
